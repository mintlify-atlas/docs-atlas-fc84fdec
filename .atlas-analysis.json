  "keyFeatures": [
    "Multi-role authentication system with granular permissions",
    "Real-time dashboard with KPIs and metrics",
    "Complete tote lifecycle management with state tracking",
    "Specialized operator interfaces for filling, dispatch, and tote operations",
    "Centralized audit system with IP tracking and user agent logging",
    "Product and location catalog management",
    "Movement history and traceability",
    "Customizable user preferences and menu ordering",
    "Alert system for expiration dates and critical events",
    "Data export functionality for records and reports"
  ],
  "publicApiSurface": [
    "POST /api/login - User authentication",
    "POST /api/logout - Session termination",
    "GET /api/dashboard/stats - Dashboard statistics",
    "GET /api/totes - List all totes",
    "POST /api/admin/totes - CRUD operations for totes",
    "PUT /api/totes/mover - Move tote to new location",
    "PUT /api/operador/totes/update-status - Update tote status",
    "GET /api/clientes - List clients",
    "POST /api/admin/clientes - CRUD operations for clients",
    "POST /api/admin/users - User management",
    "GET /api/productos - List products",
    "POST /api/admin/productos - CRUD operations for products",
    "GET /api/ubicaciones - List locations",
    "POST /api/admin/ubicaciones - CRUD operations for locations",
    "GET /api/eventos - Audit event logs",
    "GET /api/movimientos - Movement history",
    "GET /api/alertas - Active alerts",
    "GET /api/user/preferences - User preferences",
    "PUT /api/user/preferences - Update preferences"
